<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local feed holding the committed Koh.Sdk package, so a clean `dotnet build` of a game project
         can resolve `<Project Sdk="Koh.Sdk">` offline. Added alongside (not replacing) the global sources
         used to restore the game's ordinary dependencies. -->
    <add key="koh-local" value="sdk/feed" />
  </packageSources>
</configuration>
