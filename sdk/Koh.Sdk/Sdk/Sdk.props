<Project>

  <!-- The Koh SDK. A Game Boy game project consumes it by importing this file (and Sdk.targets); it
       layers on top of the standard .NET SDK so the game is an ordinary C# project that the plain
       compiler builds, `dotnet build` emits a .gb ROM, and `dotnet run` opens that ROM in the Koh
       emulator (see Sdk.targets). The same source also compiles to a managed reference binary that runs
       against the Koh.GameBoy runtime. The game references neither the compiler nor the linker - the SDK
       owns that. -->

  <PropertyGroup>
    <!-- A Koh game is an executable — the plain .NET SDK builds it into a managed reference binary (the
         Koh.GameBoy runtime), which `dotnet run` overrides to instead launch the emulator on the ROM. Set
         before the .NET SDK import so its Library default doesn't win; a project may still override. -->
    <OutputType Condition="'$(OutputType)' == ''">Exe</OutputType>
  </PropertyGroup>

  <Import Project="Sdk.props" Sdk="Microsoft.NET.Sdk" />

  <PropertyGroup>
    <!-- Repo root, three levels above sdk/Koh.Sdk/Sdk/. -->
    <KohRoot>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)../../../'))</KohRoot>
    <!-- The game pokes raw Game Boy addresses through pointers; allow unsafe by default. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Which Koh.Compiler frontend lowers the game: "csharp" (source, default) or "cil" (the
         already-built assembly). Registered names live in CompilerRegistry. -->
    <KohFrontend Condition="'$(KohFrontend)' == ''">cil</KohFrontend>
  </PropertyGroup>

  <ItemGroup>
    <!-- The reference runtime that backs Hardware.* and Gb.* on the desktop. This is the game's only
         dependency; the compiler/linker are build-time tools invoked by Sdk.targets. -->
    <ProjectReference Include="$(KohRoot)src/Koh.GameBoy/Koh.GameBoy.csproj" />
    <!-- Bring the runtime surface into scope everywhere, so game files need no `using` (and split
         cleanly across files without repeating it). -->
    <Using Include="Koh.GameBoy" />
  </ItemGroup>

</Project>
