<Project>

  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" />

  <PropertyGroup>
    <!-- The ROM lands next to the project by default (e.g. samples/gb-2048-cs/2048.gb); override
         KohRomName / KohRomPath per project. -->
    <KohRomName Condition="'$(KohRomName)' == ''">$(AssemblyName).gb</KohRomName>
    <KohRomPath Condition="'$(KohRomPath)' == ''">$(MSBuildProjectDirectory)/$(KohRomName)</KohRomPath>
    <KohBuildTasksProject>$(KohRoot)src/Koh.Build.Tasks/Koh.Build.Tasks.csproj</KohBuildTasksProject>
    <KohBuildTasksAssembly>$(KohRoot)src/Koh.Build.Tasks/bin/$(Configuration)/net10.0/Koh.Build.Tasks.dll</KohBuildTasksAssembly>
    <KohEmulatorProject>$(KohRoot)src/Koh.Emulator.App/Koh.Emulator.App.csproj</KohEmulatorProject>
    <!-- Assumes the default (no-RID) build output; a RID-scoped `dotnet run -r <rid>` places the emulator
         DLL under a rid subfolder this path does not include. -->
    <KohEmulatorAssembly>$(KohRoot)src/Koh.Emulator.App/bin/$(Configuration)/net10.0/Koh.Emulator.App.dll</KohEmulatorAssembly>
  </PropertyGroup>

  <!-- `dotnet run` opens the compiled ROM in the Koh emulator (a GL window): the build emits the ROM
       (CompileKohRom below, AfterTargets=Build) and these override the run command to exec the emulator's
       built binary on it. Unconditional and after the .NET SDK import, so it wins over the SDK's default
       RunCommand (the app host); `dotnet run` reads these properties directly. This trades the terminal
       reference renderer for the GL emulator on `dotnet run` (so it needs a display/audio device) — the
       managed reference build a game also compiles to is still the project's own binary, run it directly
       (`dotnet exec bin/<config>/net10.0/<AssemblyName>.dll`) for the terminal/headless renderer. -->
  <PropertyGroup>
    <RunCommand>dotnet</RunCommand>
    <RunArguments>exec "$(KohEmulatorAssembly)" "$(KohRomPath)"</RunArguments>
  </PropertyGroup>

  <!-- Build the emulator as part of the game's build graph so `dotnet run` can exec it, but keep it off
       the game's compile references (ReferenceOutputAssembly=false) - the game depends only on the
       Koh.GameBoy runtime, not the emulator's GL/audio stack. -->
  <ItemGroup>
    <ProjectReference Include="$(KohEmulatorProject)"
                      ReferenceOutputAssembly="false" Private="false" />
  </ItemGroup>

  <!-- The game's own C# sources (excludes generated/output files) plus the framework's HAL, written
       in the Koh C# subset (Lcd, Joypad, Tilemap/TileData, Ppu, …). The frontend compiles both as one
       translation unit, so ROMs get the framework surface; the managed-only primitives (Gb, Hardware)
       are special-cased by symbol (falling back to name matching only when no symbol resolves) and
       are not fed to it. -->
  <ItemGroup>
    <KohSource Include="$(MSBuildProjectDirectory)/**/*.cs"
               Exclude="$(MSBuildProjectDirectory)/obj/**/*.cs;$(MSBuildProjectDirectory)/bin/**/*.cs" />
    <KohFrameworkSource Include="$(KohRoot)src/Koh.GameBoy/Hal/**/*.cs" />
  </ItemGroup>

  <!-- Build the in-process compile task (and, transitively, the compiler and linker) as part of the
       build graph, so it is restored and built before use. ReferenceOutputAssembly=false keeps it off
       the game's own compile references - the game depends only on the Koh.GameBoy runtime. -->
  <ItemGroup>
    <ProjectReference Include="$(KohBuildTasksProject)"
                      ReferenceOutputAssembly="false" Private="false" />
  </ItemGroup>

  <UsingTask TaskName="Koh.Build.Tasks.CompileKohRom" AssemblyFile="$(KohBuildTasksAssembly)" />

  <!-- After the ordinary managed build succeeds, compile the game + framework HAL to a Game Boy ROM.
       The compile task assembly is an Input too, so a change to the compiler/linker/task (not just the
       game sources) re-emits the ROM instead of leaving a stale one built by the old toolchain. -->
  <Target Name="CompileKohRom" AfterTargets="Build"
          Inputs="@(KohSource);@(KohFrameworkSource);$(KohBuildTasksAssembly)"
          Outputs="$(KohRomPath)">
    <CompileKohRom SourceFiles="@(KohSource);@(KohFrameworkSource)" OutputPath="$(KohRomPath)"
                   ProgramName="$(AssemblyName)" />
    <ItemGroup>
      <FileWrites Include="$(KohRomPath)" />
    </ItemGroup>
  </Target>

</Project>
