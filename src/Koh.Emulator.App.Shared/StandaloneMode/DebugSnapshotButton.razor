@using System.Text.Json
@using System.Threading
@using Koh.Emulator.App.Services
@implements IDisposable
@inject EmulatorHost EmulatorHost
@inject IJSRuntime JS

<button class="koh-btn" @onclick="CopyAsync" title="Copy a debug state summary to the clipboard">
    @_label
</button>

@code {
    private string _label = "Snapshot";
    private CancellationTokenSource? _resetCts;
    private bool _disposed;

    protected override void OnInitialized() => EmulatorHost.StateChanged += OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    public void Dispose()
    {
        _disposed = true;
        EmulatorHost.StateChanged -= OnStateChanged;
        _resetCts?.Cancel();
        _resetCts?.Dispose();
        _resetCts = null;
    }

    private async Task CopyAsync()
    {
        // Direct dotted-path interop instead of `JS.InvokeAsync<string>("eval", ...)`.
        // The previous path would trip any host with a strict CSP (no
        // 'unsafe-eval') and silently drop the audio-stats field from every
        // snapshot. `kohWebAudio.stats()` returns a plain object which
        // serialises fine through the default JSInterop JSON path.
        string? audioStats = null;
        try
        {
            var stats = await JS.InvokeAsync<JsonElement>("kohWebAudio.stats");
            if (stats.ValueKind != JsonValueKind.Undefined && stats.ValueKind != JsonValueKind.Null)
                audioStats = stats.GetRawText();
        }
        catch { /* stats is best-effort */ }

        var text = DebugSnapshot.Build(EmulatorHost, audioStats);
        bool ok = false;
        try { ok = await JS.InvokeAsync<bool>("kohClipboard.write", text); }
        catch { ok = false; }

        _label = ok ? "Copied" : "Copy failed";
        await InvokeAsync(StateHasChanged);

        // Cancellation-based reset instead of System.Threading.Timer. The
        // previous Timer.Dispose() was non-blocking, so a callback already
        // on the ThreadPool could call InvokeAsync(StateHasChanged) on a
        // disposed component. CancellationToken's Dispose path cancels
        // cleanly and Task.Delay propagates the cancellation before we
        // touch Blazor state.
        _resetCts?.Cancel();
        _resetCts?.Dispose();
        _resetCts = new CancellationTokenSource();
        var token = _resetCts.Token;
        _ = Task.Run(async () =>
        {
            try { await Task.Delay(TimeSpan.FromSeconds(1.6), token); }
            catch (OperationCanceledException) { return; }
            if (_disposed || token.IsCancellationRequested) return;
            _label = "Snapshot";
            try { await InvokeAsync(StateHasChanged); }
            catch (ObjectDisposedException) { /* raced disposal */ }
        });
    }
}
