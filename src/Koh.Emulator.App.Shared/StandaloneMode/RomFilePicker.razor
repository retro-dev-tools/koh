@using Koh.Emulator.App.Services
@using Koh.Emulator.Core
@using Microsoft.AspNetCore.Components.Forms
@inject EmulatorHost EmulatorHost
@inject IFileSystemAccess FileSystem

@if (FileSystem.UsesNativeDialog)
{
    <button class="koh-btn is-primary" @onclick="OnNativePickAsync">Open ROM…</button>
}
else
{
    <label class="koh-btn is-primary file-button">
        Open ROM…
        <InputFile OnChange="OnBrowserFileSelected" accept=".gb,.gbc" />
    </label>
}
@if (_error is not null)
{
    <span class="status error">@_error</span>
}

@code {
    private string? _error;

    private async Task OnNativePickAsync()
    {
        _error = null;
        try
        {
            var picked = await FileSystem.PickRomAsync();
            if (picked is null) return;
            await LoadAsync(picked.Bytes);
        }
        catch (Exception ex)
        {
            _error = $"Could not load ROM: {ex.Message}";
        }
    }

    private async Task OnBrowserFileSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await LoadAsync(ms.ToArray());
        }
        catch (Exception ex)
        {
            _error = $"Could not load ROM: {ex.Message}";
        }
    }

    private async Task LoadAsync(byte[] bytes)
    {
        HardwareMode mode = (bytes.Length > 0x143 && (bytes[0x143] & 0x80) != 0)
            ? HardwareMode.Cgb
            : HardwareMode.Dmg;

        // LoadAsync on the host waits for any in-flight run loop to exit
        // before installing the new System, so loading a second ROM mid-play
        // doesn't spawn a concurrent RunAsync against the fresh GameBoySystem.
        await EmulatorHost.LoadAsync(bytes, mode);
        // Auto-start playback — no Run button, just Pause.
        _ = EmulatorHost.RunAsync();
    }
}
