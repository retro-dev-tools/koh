@using Koh.Emulator.App.Services
@using Koh.Emulator.Core.State
@using Microsoft.AspNetCore.Components.Forms
@implements IDisposable
@inject EmulatorHost EmulatorHost
@inject IJSRuntime JS

<div class="save-state-controls">
    <button @onclick="SaveState" disabled="@(EmulatorHost.System is null || EmulatorHost.OriginalRom is null)">Save State</button>
    <label>
        Load State
        <InputFile OnChange="LoadState" accept=".state" />
    </label>
    @if (_status is not null)
    {
        <span class="status">@_status</span>
    }
</div>

@code {
    private string? _status;

    protected override void OnInitialized() => EmulatorHost.StateChanged += OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => EmulatorHost.StateChanged -= OnStateChanged;

    private async Task SaveState()
    {
        if (EmulatorHost.System is null || EmulatorHost.OriginalRom is null) return;
        try
        {
            using var ms = new MemoryStream();
            SaveStateFile.Save(ms, EmulatorHost.System, EmulatorHost.OriginalRom);
            var base64 = Convert.ToBase64String(ms.ToArray());
            await JS.InvokeVoidAsync("kohDownloadFile", "koh.state", base64);
            _status = "saved";
        }
        catch (Exception ex)
        {
            _status = $"save failed: {ex.Message}";
        }
    }

    private async Task LoadState(InputFileChangeEventArgs e)
    {
        if (EmulatorHost.System is null || EmulatorHost.OriginalRom is null) return;
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 4 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;
            SaveStateFile.Load(ms, EmulatorHost.System, EmulatorHost.OriginalRom);
            _status = "loaded";
            EmulatorHost.RaiseStateChanged();
        }
        catch (Exception ex)
        {
            _status = $"load failed: {ex.Message}";
        }
    }
}
