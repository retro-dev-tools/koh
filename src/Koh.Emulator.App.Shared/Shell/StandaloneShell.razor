@using Koh.Emulator.App.Components
@using Koh.Emulator.App.Services
@using Koh.Emulator.App.StandaloneMode
@implements IDisposable
@inject EmulatorHost EmulatorHost
@inject KeyboardInputBridge Keyboard

<header class="header">
    <div class="brand">
        <span class="mark">Koh</span>
        <span class="sub">Pocket Console / N°01</span>
    </div>

    <div class="state-strip @(IsRunning ? "is-running" : "")">
        <span class="dot"></span>
        @if (EmulatorHost.System is null)
        {
            <span>Insert ROM to begin</span>
        }
        else
        {
            <span class="rom-name">@CartTitle</span>
            <span class="divider"></span>
            <span>@(EmulatorHost.IsPaused ? "Paused" : "Running")</span>
        }
    </div>

    <div class="header-actions">
        <RomFilePicker />
        <PlaybackControls />
        <SaveStateControls />
        <DebugSnapshotButton />
    </div>
</header>

<main class="stage">
    <div class="bezel">
        <span class="tick tl"></span>
        <span class="tick tr"></span>
        <span class="tick bl"></span>
        <span class="tick br"></span>
        <LcdDisplay Scale="3" />
    </div>

    <div class="keymap">
        <span class="group"><kbd>↑</kbd><kbd>↓</kbd><kbd>←</kbd><kbd>→</kbd><span class="label">D-Pad</span></span>
        <span class="group"><kbd>Z</kbd><span class="label">A</span></span>
        <span class="group"><kbd>X</kbd><span class="label">B</span></span>
        <span class="group"><kbd>Enter</kbd><span class="label">Start</span></span>
        <span class="group"><kbd>Shift</kbd><span class="label">Select</span></span>
    </div>
</main>

<details class="debug-panel">
    <summary>Diagnostics</summary>
    <div class="debug-body">
        <CpuDashboard />
    </div>
</details>

<footer class="footer">
    <span class="left">
        <span class="regmark"></span>
        <span>Koh · Sans RTC</span>
    </span>
    <span class="mid">@FooterMid</span>
    <span class="right">
        <span class="@(IsRunning ? "fps-live" : "fps-idle")">@FpsText</span>
        <span class="regmark"></span>
    </span>
</footer>

@code {
    protected override void OnInitialized()
    {
        // Wire keyboard → emulator here (in the WebView scope) so the
        // IJSRuntime captured by KeyboardInputBridge is the live BlazorWebView
        // runtime, not a root-DI ghost.
        EmulatorHost.AttachKeyboard(Keyboard);
        EmulatorHost.StateChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => EmulatorHost.StateChanged -= OnStateChanged;

    private bool IsRunning => EmulatorHost.System is not null && !EmulatorHost.IsPaused;

    private string CartTitle
    {
        get
        {
            var title = EmulatorHost.System?.Cartridge.Header.Title;
            return string.IsNullOrWhiteSpace(title) ? "Unnamed" : title;
        }
    }

    private string FooterMid
    {
        get
        {
            if (EmulatorHost.System is null) return "Ready";
            return EmulatorHost.System.Cartridge.Header.CgbFlag ? "GBC Cartridge" : "DMG Cartridge";
        }
    }

    private string FpsText => IsRunning
        ? $"{EmulatorHost.Fps,5:0.0} FPS"
        : "  --- FPS";
}
