    <ProjectReference Include="..\Koh.Linker.Core\Koh.Linker.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Pure metadata/IL reader for the CIL frontend (Frontends/Cil): a resolved object model over
         assemblies, AOT-safe (no codegen/emit surface used). This is the compiler's only frontend now
