         parity) - Koh.Compiler itself needs no Roslyn reference; the test project still uses Roslyn to
         compile fixtures to assemblies for CilFrontend to lower. -->
    <PackageReference Include="Mono.Cecil" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Koh.Compiler.Tests" />
  </ItemGroup>

