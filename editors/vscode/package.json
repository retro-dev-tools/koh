{
  "name": "koh-asm",
  "displayName": "Koh Assembly",
  "description": "Language support for Game Boy assembly — diagnostics, hover, go-to-definition, completion, document symbols",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "retro-dev-tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/retro-dev-tools/koh"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:koh-asm"
  ],
  "contributes": {
    "languages": [
      {
        "id": "koh-asm",
        "aliases": [
          "Game Boy Assembly",
          "koh-asm",
          "gbz80",
          "sm83",
          "rgbds"
        ],
        "extensions": [
          ".asm",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "koh-asm",
        "scopeName": "source.koh-asm",
        "path": "./syntaxes/koh-asm.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "koh.generateConfig",
        "title": "Koh: Generate koh.yaml"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "koh.generateConfig",
          "when": "workspaceFolderCount != 0"
        }
      ]
    },
    "breakpoints": [
      { "language": "koh-asm" }
    ],
    "debuggers": [
      {
        "type": "koh",
        "label": "Koh Game Boy Debugger",
        "languages": ["koh-asm"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program":        { "type": "string", "description": "Path to .gb / .gbc ROM" },
              "debugInfo":      { "type": "string", "description": "Path to .kdbg (phase 3+)" },
              "emulatorPath":   { "type": "string", "description": "Override path to Koh.Emulator.App executable" },
              "hardwareMode":   { "type": "string", "enum": ["auto", "dmg", "cgb"], "default": "auto" },
              "stopOnEntry":    { "type": "boolean", "default": false },
              "preLaunchTask":  { "type": "string" }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "koh",
            "request": "launch",
            "name": "Debug Koh ROM",
            "program": "${workspaceFolder}/out/game.gb",
            "stopOnEntry": false
          }
        ]
      }
    ],
    "configuration": {
      "title": "Koh Assembly",
      "properties": {
        "koh.serverPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "markdownDescription": "Path to `koh-lsp` binary. Leave empty to auto-detect."
        },
        "koh.emulator.exePath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "markdownDescription": "Absolute path to `Koh.Emulator.App` binary for debug-adapter sessions. Leave empty to fall back to the extension-relative dev-host path. Overridden per-session by `emulatorPath` in `launch.json`."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -w -p ./tsconfig.json",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.82.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
