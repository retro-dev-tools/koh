{
  "name": "koh-asm",
  "displayName": "Koh Assembly",
  "description": "Language support for Game Boy assembly — diagnostics, hover, go-to-definition, completion, document symbols",
  "version": "0.1.4",
  "license": "MIT",
  "publisher": "retro-dev-tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/retro-dev-tools/koh"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:koh-asm",
    "onDebugResolve:koh",
    "onDebugDynamicConfigurations:koh"
  ],
  "contributes": {
    "languages": [
      {
        "id": "koh-asm",
        "aliases": [
          "Game Boy Assembly",
          "koh-asm",
          "gbz80",
          "sm83",
          "rgbds"
        ],
        "extensions": [
          ".asm",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "koh-asm",
        "scopeName": "source.koh-asm",
        "path": "./syntaxes/koh-asm.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "koh.generateConfig",
        "title": "Koh: Generate koh.yaml"
      },
      {
        "command": "koh.installToolchain",
        "title": "Koh: Install Toolchain"
      },
      {
        "command": "koh.updateToolchain",
        "title": "Koh: Update Toolchain"
      },
      {
        "command": "koh.showToolchainInfo",
        "title": "Koh: Show Toolchain Info"
      },
      {
        "command": "koh.selectActiveToolchain",
        "title": "Koh: Select Active Toolchain"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "koh.generateConfig",
          "when": "workspaceFolderCount != 0"
        }
      ]
    },
    "breakpoints": [
      { "language": "koh-asm" }
    ],
    "debuggers": [
      {
        "type": "koh",
        "label": "Koh Game Boy Debugger",
        "languages": ["koh-asm"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program":        { "type": "string", "description": "Path to .gb / .gbc ROM" },
              "debugInfo":      { "type": "string", "description": "Path to .kdbg (phase 3+)" },
              "emulatorPath":   { "type": "string", "description": "Override path to Koh.Emulator.App executable" },
              "hardwareMode":   { "type": "string", "enum": ["auto", "dmg", "cgb"], "default": "auto" },
              "stopOnEntry":    { "type": "boolean", "default": false },
              "preLaunchTask":  { "type": "string" }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "koh",
            "request": "launch",
            "name": "Debug Koh ROM",
            "program": "${workspaceFolder}/out/game.gb",
            "stopOnEntry": false
          }
        ]
      }
    ],
    "configuration": {
      "title": "Koh Assembly",
      "properties": {
        "koh.toolchainPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "markdownDescription": "Override path to a Koh toolchain `bin/` (or version root). Leave empty to use the managed install under `%LOCALAPPDATA%\\Koh\\toolchain` (Windows) / `~/.local/share/koh/toolchain` (Linux) / `~/Library/Application Support/Koh/toolchain` (macOS)."
        },
        "koh.toolchain.updateCheck": {
          "type": "string",
          "enum": ["prompt", "never"],
          "default": "prompt",
          "scope": "machine",
          "markdownDescription": "When to check GitHub for a newer toolchain release. `prompt` checks on each activation and shows a non-modal message if one exists; `never` skips the check."
        },
        "koh.emulator.exePath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "markdownDescription": "Absolute path to `Koh.Emulator.App` binary for debug-adapter sessions. Leave empty to use the emulator shipped with the active toolchain. Overridden per-session by `emulatorPath` in `launch.json`."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -w -p ./tsconfig.json",
    "package": "vsce package"
  },
  "dependencies": {
    "tar": "^7.4.3",
    "vscode-languageclient": "^9.0.1",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/tar": "^6.1.13",
    "@types/vscode": "^1.82.0",
    "@types/yauzl": "^2.10.3",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
