# Source — only compiled out/ ships
src/**
tsconfig.json
**/*.map

# Dev tooling — vsce walks `dependencies` in package.json and
# includes only runtime deps, so we don't blanket-ignore node_modules.
.vscode/**
scripts/**
.gitignore
**/*.ts

# VSCE meta that doesn't belong in the package
*.vsix

# Stale local-build dirs left over from older workflows (pre-decoupled
# toolchain). The extension is now platform-agnostic and fetches its
# binaries at runtime — there's no more server/ or bin/ to ship.
server/**
bin/**
