#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Format staged C# with CSharpier, then re-stage the formatted files so the
# formatting lands in this same commit. Husky's task runner formats the
# working tree but does not re-add, so we add the formatted files back.
#
# Note: this re-adds whole files, so a file staged with only some of its
# changes will have its remaining working-tree changes included too. Stage
# complete files to avoid surprises.
dotnet husky run --group pre-commit || exit 1

git diff --cached --name-only --diff-filter=ACMR -- '*.cs' '*.csx' |
  while IFS= read -r file; do
    [ -f "$file" ] && git add -- "$file"
  done
