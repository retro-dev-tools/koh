{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "csharpier",
         "group": "pre-commit",
         "command": "dotnet",
         "args": [ "csharpier", "check", "${staged}" ],
         "include": [ "**/*.cs", "**/*.csx" ]
      }
   ]
}
