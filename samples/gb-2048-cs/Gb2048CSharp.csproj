<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Koh.Samples.Gb2048CSharp</RootNamespace>
  </PropertyGroup>

  <!-- 2048.cs is the Game Boy source: it is compiled by the Koh C# frontend, not by
       this .NET project. Exclude it from the SDK's default compilation glob (and keep it
       visible in the IDE as a plain file). -->
  <ItemGroup>
    <Compile Remove="2048.cs" />
    <None Include="2048.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Koh.Compiler\Koh.Compiler.csproj" />
    <ProjectReference Include="..\..\src\Koh.Linker.Core\Koh.Linker.Core.csproj" />
  </ItemGroup>

</Project>
